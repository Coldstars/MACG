# Copy this file to .env and fill values as needed.
# Do not commit real API keys.

# Recommended for YouTube creator discovery.
YOUTUBE_API_KEY=

# Optional generic SERP API if you want web search discovery.
# If using a URL template in config/sources.yaml that needs a key, put it here.
SERP_API_KEY=

# Optional override for workspace root.
# Default is ../../workspaces relative to tools/channel-finder.
WORKSPACE_ROOT=
